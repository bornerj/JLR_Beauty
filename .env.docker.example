# =============================================================
# JLR Beauty — variáveis de ambiente para Docker / VPS
# Copie para .env e preencha os valores antes de rodar
# =============================================================

# --- PostgreSQL ---
POSTGRES_DB=jlrbeauty
POSTGRES_USER=jlrbeauty
POSTGRES_PASSWORD=TROQUE_POR_SENHA_SEGURA

# --- API (Express) ---
DATABASE_URL=postgresql://jlrbeauty:TROQUE_POR_SENHA_SEGURA@postgres:5432/jlrbeauty
PORT=3001

APP_API_URL=http://SEU_DOMINIO_OU_IP
APP_WEB_URL=http://SEU_DOMINIO_OU_IP
CORS_ORIGIN=http://SEU_DOMINIO_OU_IP

JWT_SECRET=TROQUE_POR_SECRET_COM_MINIMO_32_CARACTERES
JWT_EXPIRES_IN=12h

AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=8
AUTH_RATE_LIMIT_BLOCK_MS=900000

# --- Usuário master (criado no seed) ---
MASTER_EMAIL=seu@email.com
MASTER_PASSWORD=SenhaSeguraMaster@123

# --- Stripe (deixe em false para desativar) ---
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=
STRIPE_CHECKOUT_CURRENCY=brl

# --- Z-API (WhatsApp Concierge) ---
ZAPI_WEBHOOK_SECRET=TROQUE_POR_SECRET_ZAPI

# --- Concierge ---
CONCIERGE_RETENTION_DAYS=180
CONCIERGE_RETENTION_INTERVAL_HOURS=24
