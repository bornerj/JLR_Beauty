// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MASTER
  ADMIN
  MANAGER
  PROFESSIONAL
  CLIENT
}

enum CategoryStatus {
  ACTIVE
  INACTIVE
}

enum StatusColor {
  VERDE
  AMARELO
  VERMELHO
  CINZA
}

enum UserStatus {
  ATIVO
  INATIVO
  SUSPENSO
  CANCELADO
}

enum OrderStatus {
  PENDENTE
  PAGO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum FulfillmentStatus {
  PENDENTE
  SEPARANDO
  EMBALADO
  DESPACHADO
  ENVIADO
  ENTREGUE
  CANCELADO
}

enum PaymentStatus {
  PENDENTE
  APROVADO
  RECUSADO
  CANCELADO
  REEMBOLSADO
}

enum AppointmentStatus {
  PENDENTE
  CONFIRMADO
  CANCELADO
}

enum SubscriptionStatus {
  ATIVA
  PENDENTE
  CANCELADA
  INADIMPLENTE
}

enum ConciergeOrigin {
  WEB
  WHATSAPP
}

enum ConciergeStep {
  SERVICE
  UNIT
  DATE
  SLOT
  NAME
  COMPLETED
}

enum ConciergeSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model Setting {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("ContentEntry")
}

model DiscountCoupon {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  discountType String
  percentOff  Decimal? @db.Decimal(5, 2)
  amountOff   Decimal? @db.Decimal(10, 2)
  minSubtotal Decimal? @db.Decimal(10, 2)
  startsAt    DateTime?
  endsAt      DateTime?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ProductCategory {
  id        Int      @id @default(autoincrement())
  name      String
  status    CategoryStatus @default(ACTIVE)
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceCategory {
  id        Int      @id @default(autoincrement())
  name      String
  status    CategoryStatus @default(ACTIVE)
  services  Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductStatus {
  id        Int      @id @default(autoincrement())
  name      String
  color     StatusColor @default(VERDE)
  products  Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceStatus {
  id        Int      @id @default(autoincrement())
  name      String
  color     StatusColor @default(VERDE)
  services  Service[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          Int        @id @default(autoincrement())
  name        String
  description String?    @db.Text
  sku         String?
  stock       Int        @default(0)
  price       Decimal    @db.Decimal(10, 2)
  imageUrl    String?
  benefits    Json?
  isFeatured  Boolean    @default(false)
  productCategoryId  Int?
  productCategory    ProductCategory? @relation(fields: [productCategoryId], references: [id])
  productStatusId    Int?
  productStatus      ProductStatus?   @relation(fields: [productStatusId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Service {
  id          Int        @id @default(autoincrement())
  name        String
  description String?    @db.Text
  price       Decimal    @db.Decimal(10, 2)
  cost        Decimal?   @db.Decimal(10, 2)
  durationMin Int?
  commissionPercent Int?
  imageUrl    String?
  isFeatured  Boolean    @default(false)
  serviceCategoryId  Int?
  serviceCategory    ServiceCategory? @relation(fields: [serviceCategoryId], references: [id])
  serviceStatusId    Int?
  serviceStatus      ServiceStatus?   @relation(fields: [serviceStatusId], references: [id])
  orderItems  OrderItem[]
  appointments Appointment[]
  conciergeSessions ConciergeSession[]
  professionalServices ProfessionalService[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Membership {
  id          Int            @id @default(autoincrement())
  name        String
  title       String
  description String?        @db.Text
  price       Decimal        @db.Decimal(10, 2)
  benefits    Json?
  isFeatured  Boolean        @default(false)
  status      String         @default("Ativo")
  subscriptions Subscription[]
  orderItems  OrderItem[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Subscription {
  id           Int               @id @default(autoincrement())
  membershipId Int
  membership   Membership        @relation(fields: [membershipId], references: [id])
  status       SubscriptionStatus @default(PENDENTE)
  customerName String?
  customerEmail String?
  customerPhone String?
  startedAt    DateTime          @default(now())
  cancelledAt  DateTime?
  payments     Payment[]
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
}

model Order {
  id                   Int                @id @default(autoincrement())
  publicCode           String?            @unique
  status               OrderStatus        @default(PENDENTE)
  fulfillmentStatus    FulfillmentStatus  @default(PENDENTE)
  total                Decimal            @db.Decimal(10, 2)
  customerName         String?
  customerEmail        String?
  customerPhone        String?
  paymentConfirmedAt   DateTime?
  separatedAt          DateTime?
  packedAt             DateTime?
  dispatchedAt         DateTime?
  shipmentTrackingCode String?
  shipmentCarrier      String?
  shippedAt            DateTime?
  deliveredAt          DateTime?
  fulfillmentNotes     String?            @db.Text
  items                OrderItem[]
  payments             Payment[]
  appointments         Appointment[]
  statusHistory        OrderStatusHistory[]
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
}

model OrderItem {
  id           Int        @id @default(autoincrement())
  orderId      Int
  productId    Int?
  membershipId Int?
  serviceId    Int?
  quantity     Int        @default(1)
  unitPrice    Decimal    @db.Decimal(10, 2)
  order        Order      @relation(fields: [orderId], references: [id])
  product      Product?   @relation(fields: [productId], references: [id])
  membership   Membership? @relation(fields: [membershipId], references: [id])
  service      Service?   @relation(fields: [serviceId], references: [id])
}

model Payment {
  id                 Int          @id @default(autoincrement())
  orderId            Int?
  subscriptionId     Int?
  provider           String
  providerPaymentId  String?
  status             PaymentStatus @default(PENDENTE)
  amount             Decimal       @db.Decimal(10, 2)
  method             String?
  paidAt             DateTime?
  rawPayload         Json?
  order              Order?        @relation(fields: [orderId], references: [id])
  subscription       Subscription? @relation(fields: [subscriptionId], references: [id])
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model OrderStatusHistory {
  id         Int         @id @default(autoincrement())
  orderId    Int
  fromStatus OrderStatus?
  toStatus   OrderStatus
  source     String
  note       String?     @db.Text
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())

  @@index([orderId, createdAt])
}

model StripeWebhookEvent {
  id           Int      @id @default(autoincrement())
  eventId      String   @unique
  eventType    String
  livemode     Boolean  @default(false)
  status       String   @default("PROCESSED")
  errorMessage String?  @db.Text
  payload      Json?
  processedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Unit {
  id        Int           @id @default(autoincrement())
  name      String
  address   String?
  hourStart String        @default("09:00")
  hourFinish String       @default("18:00")
  professionals Professional[]
  professionalShifts ProfessionalShift[]
  appointments Appointment[]
  appointmentSlots AppointmentSlot[]
  waitlistMessages AppointmentWaitlistMessage[]
  conciergeSessions ConciergeSession[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model ConciergeSession {
  id            Int                    @id @default(autoincrement())
  origin        ConciergeOrigin
  phone         String
  status        ConciergeSessionStatus @default(ACTIVE)
  step          ConciergeStep          @default(SERVICE)
  serviceId     Int?
  unitId        Int?
  slotLabel     String?
  scheduledDateLabel String?
  scheduledFor  DateTime?
  customerName  String?
  summaryText   String?                 @db.Text
  lastInboundAt DateTime?
  completedAt   DateTime?
  summarySentAt DateTime?
  service       Service?               @relation(fields: [serviceId], references: [id])
  unit          Unit?                  @relation(fields: [unitId], references: [id])
  events        ConciergeEvent[]
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@index([phone, status, createdAt])
  @@index([scheduledFor])
}

model ConciergeEvent {
  id         Int              @id @default(autoincrement())
  sessionId  Int
  direction  String
  channel    ConciergeOrigin
  phone      String?
  text       String           @db.Text
  session    ConciergeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  createdAt  DateTime         @default(now())

  @@index([sessionId, createdAt])
}

model ProfessionalCommissionProfile {
  id                Int              @id @default(autoincrement())
  name              String           @unique
  commissionPercent Decimal          @default(0) @db.Decimal(5, 2)
  status            CategoryStatus   @default(ACTIVE)
  professionals     Professional[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model ProfessionalWorkProfile {
  id                                   Int            @id @default(autoincrement())
  title                                String         @unique
  status                               CategoryStatus @default(ACTIVE)
  canScheduleAppointments              Boolean        @default(false)
  canAccessOtherProfessionalsAgenda    Boolean        @default(false)
  canViewServiceValues                 Boolean        @default(false)
  canViewCustomerContact               Boolean        @default(false)
  canAccessMenuClientsAnamnese         Boolean        @default(false)
  canAccessMenuServices                Boolean        @default(false)
  canAccessMenuProducts                Boolean        @default(false)
  canAccessMenuExpenses                Boolean        @default(false)
  canViewCommissionsToReceive          Boolean        @default(false)
  canViewCommissionPayments            Boolean        @default(false)
  canEditAppointments                  Boolean        @default(false)
  canDeleteAppointments                Boolean        @default(false)
  canCreateServiceInAppointment        Boolean        @default(false)
  canViewGrossCommissionsToPay         Boolean        @default(false)
  professionals                        Professional[]
  createdAt                            DateTime       @default(now())
  updatedAt                            DateTime       @updatedAt
}

model Professional {
  id                 Int                          @id @default(autoincrement())
  name               String
  userId             Int                          @unique
  specialties        Json?
  unitId             Int?
  employmentStatus   CategoryStatus               @default(ACTIVE)
  startedAt          DateTime?
  endedAt            DateTime?
  commissionPercent  Decimal?                     @db.Decimal(5, 2)
  commissionProfileId Int?
  workProfileId      Int?
  unit               Unit?                        @relation(fields: [unitId], references: [id])
  user               User                         @relation("ProfessionalUser", fields: [userId], references: [id])
  commissionProfile  ProfessionalCommissionProfile? @relation(fields: [commissionProfileId], references: [id])
  workProfile        ProfessionalWorkProfile?     @relation(fields: [workProfileId], references: [id])
  appointments       Appointment[]
  appointmentSlots AppointmentSlot[]
  professionalServices ProfessionalService[]
  shifts             ProfessionalShift[]
  createdAt          DateTime                     @default(now())
  updatedAt          DateTime                     @updatedAt

  @@index([commissionProfileId])
  @@index([workProfileId])
}

model Customer {
  id           Int      @id @default(autoincrement())
  userId       Int?     @unique
  name         String
  phone        String   @unique
  email        String?
  city         String?
  state        String?
  neighborhood String?
  phone2       String?
  phone2OptOut Boolean  @default(false)
  notes        String?  @db.Text
  user         User?    @relation("CustomerUser", fields: [userId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([phone])
}

model Appointment {
  id            Int               @id @default(autoincrement())
  unitId        Int
  professionalId Int
  serviceId     Int
  clientId      Int?
  orderId       Int?
  start         DateTime
  end           DateTime?
  clientName    String
  clientPhone   String
  notes         String?
  status        AppointmentStatus @default(PENDENTE)
  unit          Unit              @relation(fields: [unitId], references: [id])
  professional  Professional      @relation(fields: [professionalId], references: [id])
  service       Service           @relation(fields: [serviceId], references: [id])
  client        User?             @relation(fields: [clientId], references: [id])
  order         Order?            @relation(fields: [orderId], references: [id])
  slots         AppointmentSlot[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([unitId, start])
  @@index([professionalId, start])
  @@index([clientId, start])
}

model ProfessionalService {
  professionalId Int
  serviceId      Int
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service        Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@id([professionalId, serviceId])
  @@index([serviceId, professionalId])
}

model ProfessionalShift {
  id             Int          @id @default(autoincrement())
  professionalId Int
  unitId         Int
  workDate       DateTime
  hourStart      String
  hourFinish     String
  isActive       Boolean      @default(true)
  notes          String?
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([unitId, workDate, isActive])
  @@index([professionalId, workDate, isActive])
  @@unique([professionalId, workDate, hourStart, hourFinish])
}

model AppointmentSlot {
  id             Int          @id @default(autoincrement())
  appointmentId  Int
  unitId         Int
  professionalId Int
  slotStart      DateTime
  slotEnd        DateTime
  appointment    Appointment  @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  unit           Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@unique([unitId, professionalId, slotStart])
  @@index([appointmentId, slotStart])
  @@index([unitId, slotStart])
  @@index([professionalId, slotStart])
}

model AppointmentWaitlistMessage {
  id             Int      @id @default(autoincrement())
  unitId         Int
  requestedDate  DateTime
  serviceName    String
  clientName     String?
  clientPhone    String
  notes          String?
  status         String   @default("PENDING")
  unit           Unit     @relation(fields: [unitId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([unitId, requestedDate, status])
}

model FranchiseLead {
  id        Int      @id @default(autoincrement())
  name      String
  email     String?
  phone     String?
  city      String?
  status    String?  @default("Novo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LoginAttempt {
  key             String   @id
  failures        Int      @default(0)
  windowStartedAt DateTime @default(now())
  blockedUntil    DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([blockedUntil])
  @@map("login_attempts")
}

model User {
  id           Int      @id @default(autoincrement())
  name         String
  email        String   @unique
  phone        String?
  phone2       String?
  city         String?
  neighborhood String?
  avatarUrl    String?
  status       UserStatus @default(ATIVO)
  emailVerified Boolean @default(false)
  rating       Int?
  lastAccessAt DateTime?
  role         Role     @default(CLIENT)
  passwordHash String?
  professionalProfile Professional? @relation("ProfessionalUser")
  customerProfile Customer?         @relation("CustomerUser")
  appointments Appointment[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
